{
  "_comment": "Example openclaw.json for NemoClaw NVIDIA stack. Copy to .openclaw/openclaw.json and fill in secrets/paths. Configure models.providers (e.g. LiteLLM) so litellm-local/openclaw-opus-46 resolves. Full roster: docs/FLEET-ROSTER.md. Chief-only forum group pattern: docs/CHIEF-FORUM-GROUP.md.",
  "models": {
    "mode": "merge",
    "providers": {}
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "nvidia/nemotron-3-super-120b-a12b"
      },
      "workspace": "/home/YOU/nemoclaw/workspace-default",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      { "id": "main" },
      {
        "id": "chief",
        "name": "chief",
        "workspace": "/home/YOU/nemoclaw/agents/chief",
        "agentDir": "/home/YOU/.openclaw/agents/chief/agent"
      },
      {
        "id": "gitbob",
        "name": "gitbob",
        "workspace": "/home/YOU/nemoclaw/agents/github-bob",
        "agentDir": "/home/YOU/.openclaw/agents/gitbob/agent"
      },
      {
        "id": "kubekate",
        "name": "kubekate",
        "workspace": "/home/YOU/nemoclaw/agents/k8s-kate",
        "agentDir": "/home/YOU/.openclaw/agents/kubekate/agent"
      },
      {
        "id": "grafgreg",
        "name": "grafgreg",
        "workspace": "/home/YOU/nemoclaw/agents/grafana-greg",
        "agentDir": "/home/YOU/.openclaw/agents/grafgreg/agent"
      },
      {
        "id": "snow-birdman",
        "name": "snow-birdman",
        "workspace": "/home/YOU/nemoclaw/agents/snow-birdman",
        "agentDir": "/home/YOU/.openclaw/agents/snow-birdman/agent"
      },
      {
        "id": "mcp-builder",
        "name": "mcp-builder",
        "workspace": "/home/YOU/nemoclaw/agents/mcp-builder",
        "agentDir": "/home/YOU/.openclaw/agents/mcp-builder/agent"
      },
      {
        "id": "skill-builder",
        "name": "skill-builder",
        "workspace": "/home/YOU/nemoclaw/agents/skill-builder",
        "agentDir": "/home/YOU/.openclaw/agents/skill-builder/agent",
        "model": {
          "primary": "litellm-local/openclaw-opus-46"
        }
      }
    ]
  },
  "bindings": [
    { "type": "route", "agentId": "chief",    "match": { "channel": "telegram", "accountId": "chief" } },
    { "type": "route", "agentId": "gitbob",   "match": { "channel": "telegram", "accountId": "gitbob" } },
    { "type": "route", "agentId": "kubekate", "match": { "channel": "telegram", "accountId": "kubekate" } },
    { "type": "route", "agentId": "grafgreg", "match": { "channel": "telegram", "accountId": "grafgreg" } },
    { "type": "route", "agentId": "snow-birdman", "match": { "channel": "telegram", "accountId": "snow-birdman" } }
  ],
  "skills": {
    "load": {
      "extraDirs": [
        "/home/YOU/nemoclaw/openclaw-skills"
      ]
    },
    "entries": {}
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "groups": {
        "-100YOUR_SUPERGROUP_ID": {
          "requireMention": true,
          "enabled": true,
          "topics": {
            "1": { "requireMention": true, "agentId": "chief" },
            "*": { "requireMention": false, "agentId": "chief" }
          }
        }
      },
      "accounts": {
        "chief": {
          "name": "chief",
          "enabled": true,
          "tokenFile": "/home/YOU/.openclaw/secrets/telegram/chief.token",
          "groups": {
            "-100YOUR_SUPERGROUP_ID": {
              "requireMention": true,
              "enabled": true,
              "topics": {
                "1": { "requireMention": true, "groupPolicy": "open", "agentId": "chief" },
                "*": { "requireMention": false, "groupPolicy": "open", "agentId": "chief" }
              }
            }
          }
        },
        "gitbob": {
          "name": "gitbob",
          "enabled": true,
          "tokenFile": "/home/YOU/.openclaw/secrets/telegram/gitbob.token"
        },
        "kubekate": {
          "name": "kubekate",
          "enabled": true,
          "tokenFile": "/home/YOU/.openclaw/secrets/telegram/kubekate.token"
        },
        "grafgreg": {
          "name": "grafgreg",
          "enabled": true,
          "tokenFile": "/home/YOU/.openclaw/secrets/telegram/grafgreg.token"
        },
        "snow-birdman": {
          "name": "snow-birdman",
          "enabled": false,
          "tokenFile": "/home/YOU/.openclaw/secrets/telegram/snow-birdman.token"
        }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "GENERATE_A_RANDOM_TOKEN_HERE"
    }
  },
  "plugins": {
    "entries": {
      "telegram": { "enabled": true }
    }
  }
}
