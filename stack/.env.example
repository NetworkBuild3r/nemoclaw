# NemoClaw — Archivist stack environment
# Copy to stack/.env and fill in API keys.

# Embeddings — NVIDIA NIM (nv-embedqa-e5-v5, 1024-dim)
EMBED_URL=https://integrate.api.nvidia.com
EMBED_MODEL=nvidia/nv-embedqa-e5-v5
EMBED_API_KEY=nvapi-YOUR_NVIDIA_API_KEY
EMBED_PROVIDER=nvidia
VECTOR_DIM=1024

# LLM — NVIDIA cloud (OpenAI-compatible)
LLM_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b
LLM_API_KEY=nvapi-YOUR_NVIDIA_API_KEY

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=nemoclaw_memories

# Storage
MEMORY_ROOT=/data/memories
SQLITE_PATH=/data/archivist/graph.db
NAMESPACES_CONFIG_PATH=/data/archivist/config/namespaces.yaml
TEAM_MAP_PATH=/data/archivist/config/team_map.yaml

# Retrieval
RETRIEVAL_THRESHOLD=0.55
RERANK_ENABLED=false

# Server
MCP_PORT=3100

# Curator
CURATOR_INTERVAL_MINUTES=30

# Metrics
METRICS_ENABLED=true
