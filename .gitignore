.env
.env.*
!.env.example
*.token
**/secrets/

# LiteLLM — real keys must never be pushed (use litellm-config.yaml.example + env / Vault)
stack/litellm-config.yaml

# Deployment-specific config — use *.example templates for portable copies
config/mcporter.json
config/policies/archivist.preset.yaml
config/policies/mcp_aggregator.preset.yaml
config/policies/k8s_ssh.preset.yaml

# Upstream NemoClaw clone (~1GB) — document `git clone https://github.com/NVIDIA/NemoClaw` instead
vendor/NemoClaw/

# Optional: restore archivist submodule workflow from this backup (not for git)
.upstream-archivist-git-backup/

# Python / tooling
**/__pycache__/
*.pyc
.pytest_cache/

# OpenClaw global state (co-located under repo; ~/.openclaw is a symlink)
.openclaw/*
!.openclaw/README.md

# NemoClaw state (co-located under repo; ~/.nemoclaw is a symlink)
.nemoclaw/*
!.nemoclaw/README.md

# Cursor IDE metadata (local only)
**/.cursor/

# Nested repos under GitBob agent (local clones; not submodules)
agents/github-bob/nemoclaw/
agents/github-bob/home_k3/

# Per-agent OpenClaw workspace metadata (local only; not for public repo)
agents/*/.openclaw/

# Vault / systemd env files (canonical under repo; ~/.config/openclaw may symlink here)
.config/openclaw/*
!.config/openclaw/README.md
